# AWS profile for the MCP proxy server
AWS_PROFILE=your-aws-profile-name

# Paths to npx and uvx binaries (optional — defaults to "npx" and "uvx" if on PATH)
NPX_PATH=/path/to/npx
UVX_PATH=/path/to/uvx

# LiteLLM proxy configuration
LITELLM_API_BASE_URL=http://litellm.somedomain
LITELLM_API_KEY=your-litellm-api-key

# Required by the OpenAI Agents SDK (set to any non-empty value when using LiteLLM)
OPENAI_API_KEY=unused
